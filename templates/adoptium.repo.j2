[Adoptium]
name=Adoptium
baseurl=https://packages.adoptium.net/artifactory/rpm/{% if ansible_facts['distribution'] == 'Fedora' %}fedora{% else %}rhel{% endif %}/{{ ansible_facts['distribution_major_version'] }}/{{ ansible_facts['architecture'] }}
enabled=1
gpgcheck=1
gpgkey=https://packages.adoptium.net/artifactory/api/gpg/key/public
